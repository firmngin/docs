                "root": "libraries/javascript",
                "pages": [
                  "libraries/javascript/installation",
                  "libraries/javascript/configuration",
                  "libraries/javascript/entities",
                  "libraries/javascript/events",
                  "libraries/javascript/examples"
                ]
              },
              {
                "group": "Python SDK",
                "root": "libraries/raspi",
                "pages": [
                  "libraries/raspi/installation",
                  "libraries/raspi/configuration",
                  "libraries/raspi/entities",
                  "libraries/raspi/events",
                  "libraries/raspi/examples"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          }
        ]
      }
