              },
              "automations",
              "mcp",
              "channels",
              "plans"
            ]
          },
          {
            "group": "Monetization",
            "pages": [
              "monetization",
              "monetization/merchant-setup",
              "monetization/prepaid",
              "monetization/postpaid",
              "monetization/payouts",
              "payment-channels",
              "live-merchant-verification"
            ]
          },
          {
            "group": "Libraries",
            "pages": [
